{
  "name": "@firela/api-types",
  "version": "0.0.0",
  "description": "TypeScript types generated from OpenAPI specifications",
  "license": "MIT",
  "author": "FireLa Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/fire-la/api-specs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/generated/sdk.gen.d.ts",
      "import": "./dist/generated/sdk.gen.js",
      "default": "./dist/generated/sdk.gen.js"
    }
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc",
    "lint": "spectral lint openapi.yaml",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.4.0",
    "@hey-api/openapi-ts": "^0.45.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "typescript": "^5.3.0"
  }
}
